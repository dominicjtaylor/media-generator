# ============================================================
# Instagram Carousel Automation — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ------------------------------------------------------------
# Contentdrips credentials
# ------------------------------------------------------------
CONTENTDRIPS_EMAIL=your_email@example.com
CONTENTDRIPS_PASSWORD=your_password_here

# ------------------------------------------------------------
# LLM provider — "anthropic" (default) or "openai"
# ------------------------------------------------------------
LLM_PROVIDER=anthropic

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ------------------------------------------------------------
# ngrok (for phone access without being on the same WiFi)
# Get token:  https://dashboard.ngrok.com/get-started/your-authtoken
# Get domain: https://dashboard.ngrok.com/domains  (free static URL)
# ------------------------------------------------------------
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
NGROK_DOMAIN=                            # e.g. your-name.ngrok-free.app (optional)

# ------------------------------------------------------------
# Optional: Instagram auto-post (stub — future use)
# ------------------------------------------------------------
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_ACCOUNT_ID=
